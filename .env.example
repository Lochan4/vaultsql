# VaultSQL environment variables
# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# Redis (defaults work if running locally or via docker-compose)
REDIS_HOST=localhost
REDIS_PORT=6379

# MongoDB (defaults work if running locally or via docker-compose)
MONGO_URI=mongodb://localhost:27017

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: override default model tiers (see core/claude_runner.py)
# MODEL_SQL_SIMPLE=claude-haiku-4-5-20251001
# MODEL_SQL_MEDIUM=claude-sonnet-4-6
# MODEL_SQL_COMPLEX=claude-sonnet-4-6
